NODE_ENV=development
PORT=3000
LOG_LEVEL=info
API_PREFIX=/api
API_VERSION=v1

# LLM Provider
LLM_PROVIDER=gemini
LLM_DEFAULT_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY=

# iMach360 Connector (IMACH360_API_URL is required)
IMACH360_API_URL=https://www.imach360.com

# Option A — Credential login (recommended: token auto-refreshes, no manual rotation)
IMACH360_SERVICE_EMAIL=admin@yourcompany.com
IMACH360_SERVICE_PASSWORD=

# Option B — Static JWT (comment out Option A and uncomment this if preferred)
# IMACH360_SERVICE_TOKEN=

IMACH360_LEAVE_ANNUAL_ENTITLEMENT=20

# CORS — comma-separated. Omit to allow all origins (dev only).
# Production: set to your iMach360 domain exactly as the browser sees it.
# ALLOWED_ORIGINS=https://www.imach360.com,https://app.imach360.com

# Storage
DATABASE_URL=
